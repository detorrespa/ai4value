# ==============================================
# AI4Value Diagnóstico - Variables de entorno
# ==============================================
# Copia este archivo a .env.local y rellena los valores

# --- OBLIGATORIO: Resend para enviar el Word por email ---
# Crea cuenta gratis en resend.com (3000 emails/mes gratis)
RESEND_API_KEY=

# --- Emails ---
# Remitente (usa onboarding@resend.dev para empezar sin verificar dominio)
LEAD_FROM_EMAIL=onboarding@resend.dev
# Dónde recibes las notificaciones de lead nuevo
LEAD_NOTIFICATION_EMAIL=alberto@nektiu.com

# --- RECOMENDADO: Webhook para Google Sheet (vía Make/n8n/Zapier) ---
# Envía cada lead al webhook para guardarlo en tu Sheet
LEAD_WEBHOOK_URL=

# --- OPCIONAL: Vercel Blob (para guardar el Word en la nube) ---
# Se configura automáticamente cuando conectas Blob en Vercel
# (Settings → Storage → Create Database → Blob)
BLOB_READ_WRITE_TOKEN=

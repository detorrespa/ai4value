# AI4Value Diagnóstico - Configuración
# Copia este archivo a .env.local y rellena los valores

# --- Opción A: Webhook a Make / n8n / Zapier (recomendado) ---
# Cada lead se envía a esta URL vía POST con JSON
LEAD_WEBHOOK_URL=

# --- Opción B: Resend para enviar emails ---
# Crea una cuenta en resend.com y obtén la API key
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=alberto@nektiu.com
LEAD_FROM_EMAIL=diagnostico@nektiu.com

# --- Público (visible en el cliente) ---
NEXT_PUBLIC_COMPANY_NAME=Nektiu
NEXT_PUBLIC_CONTACT_EMAIL=alberto@nektiu.com
